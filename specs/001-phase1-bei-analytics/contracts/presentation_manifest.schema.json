{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heatmap-hackathon.local/contracts/presentation_manifest.schema.json",
  "title": "Presentation Manifest",
  "description": "Frontend-facing contract for scope-aware precomputed analytics payloads.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "generated_at",
    "profile",
    "scenarios",
    "assets",
    "methodology",
    "ui_defaults"
  ],
  "properties": {
    "manifest_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "display_name",
        "scope_level",
        "output_prefix"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "display_name": {
          "type": "string"
        },
        "scope_level": {
          "type": "string",
          "enum": ["state", "region", "national"]
        },
        "output_prefix": {
          "type": "string"
        },
        "origin_state_fips": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "destination_region": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "scenarios": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default",
        "enabled"
      ],
      "properties": {
        "default": {
          "type": "string",
          "enum": ["ground_only", "ground_plus_air"]
        },
        "enabled": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["ground_only", "ground_plus_air"]
          }
        }
      }
    },
    "assets": {
      "type": "object",
      "description": "Map/table assets keyed by geography level and scenario.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "table": {
              "type": "string"
            },
            "geojson": {
              "type": "string"
            },
            "rankings": {
              "type": "string"
            }
          }
        }
      }
    },
    "facility_assets": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "methodology": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "data_sources",
        "limitations",
        "scope_note"
      ],
      "properties": {
        "data_sources": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "scope_note": {
          "type": "string"
        }
      }
    },
    "ui_defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "geography_level",
        "metric",
        "map_center",
        "map_zoom"
      ],
      "properties": {
        "geography_level": {
          "type": "string",
          "enum": ["tract", "county", "state"]
        },
        "metric": {
          "type": "string"
        },
        "map_center": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "number"
          }
        },
        "map_zoom": {
          "type": "number"
        },
        "narrative_order": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
