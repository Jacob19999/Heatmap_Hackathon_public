{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://burncare-equity/specs/004-results-pipeline/contracts/artifact-manifest.schema.json",
  "title": "Artifact Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "profile",
    "created_at",
    "artifacts"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 6
    },
    "profile": {
      "type": "string",
      "enum": [
        "mvp",
        "full",
        "stage"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_id",
          "stage_id",
          "artifact_type",
          "path",
          "format"
        ],
        "properties": {
          "artifact_id": {
            "type": "string",
            "minLength": 6
          },
          "stage_id": {
            "type": "string",
            "pattern": "^(0[0-9]|10)$"
          },
          "artifact_type": {
            "type": "string",
            "enum": [
              "dataset",
              "table",
              "figure",
              "finding",
              "manifest"
            ]
          },
          "artifact_role": {
            "type": "string"
          },
          "scenario_id": {
            "type": "string",
            "enum": [
              "ground_only",
              "ground_plus_air"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "format": {
            "type": "string",
            "enum": [
              "parquet",
              "csv",
              "json",
              "geojson",
              "png",
              "md"
            ]
          }
        }
      }
    }
  }
}
